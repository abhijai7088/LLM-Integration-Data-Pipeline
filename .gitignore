# =============================================================================
# SECRETS — never commit API keys or credentials
# =============================================================================
.env
*.key
*.pem
*.p12
secrets/

# =============================================================================
# PYTHON
# =============================================================================

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
