# =============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# =============================================================================
# RUNTIME OUTPUTS
# Run outputs are regenerated by the pipeline on each execution.
# EXCEPTION: the sample_outputs/ directory IS committed per assignment rules
#            (the assignment explicitly requires sample output files in the repo).
# =============================================================================

# Any ad-hoc output directories created with --output-dir
outputs/
output/
results/

# Log files (runtime artefacts; not source code)
logs/
*.log

